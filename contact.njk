---
layout: layout.njk
permalink: "/contact.html"
title: "Contact Us — Quan Zhen Cultural Society · 全真教化協會"
description: "Contact Quan Zhen Cultural Society (全真教化協會) — get in touch via Facebook Messenger, email, or our contact form. Find us on Facebook."
ogTitle: "Contact Us — Quan Zhen Cultural Society"
ogDescription: "Get in touch with Quan Zhen Cultural Society — enquiries about membership, events, media, and general questions."
activeNav: contact
bilingualNav: true
showOfferings: false
pageStyle: |
  .page-hero { background: var(--navy-primary); padding: 140px 0 80px; border-bottom: 1px solid rgba(201,168,76,0.2); }
  .page-hero-inner { max-width: 640px; }
  .page-hero h1 { color: var(--rice-paper); margin-bottom: 16px; }
  .page-hero p { color: var(--muted-sky); font-size: 16px; line-height: 1.75; }

  .contact-layout { display: grid; grid-template-columns: 1fr 1.6fr; gap: 48px; align-items: start; }

  .contact-methods { display: flex; flex-direction: column; gap: 16px; }
  .contact-method {
    background: var(--white); border: 0.5px solid rgba(26,39,68,0.1); border-radius: var(--radius-lg); padding: 20px;
    display: flex; gap: 14px; align-items: flex-start; text-decoration: none; transition: border-color 0.2s, transform 0.2s;
  }
  .contact-method:hover { border-color: rgba(201,168,76,0.4); transform: translateY(-1px); }
  .contact-method-icon { width: 40px; height: 40px; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 16px; }
  .icon-wa { background: rgba(37,211,102,0.1); }
  .icon-email { background: rgba(26,39,68,0.08); }
  .icon-fb { background: rgba(24,119,242,0.1); }
  .icon-ig { background: rgba(225,48,108,0.1); }
  .icon-yt { background: rgba(255,0,0,0.08); }
  .contact-method-label { font-size: 11px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--brass-gold); margin-bottom: 3px; }
  .contact-method-value { font-size: 14px; font-weight: 500; color: var(--navy-primary); margin-bottom: 3px; }
  .contact-method-note { font-size: 11px; color: #888; line-height: 1.5; }

  .social-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-top: 8px; }
  .social-card { background: var(--white); border: 0.5px solid rgba(26,39,68,0.1); border-radius: var(--radius-lg); padding: 16px; text-align: center; text-decoration: none; transition: border-color 0.2s; }
  .social-card:hover { border-color: rgba(201,168,76,0.4); }
  .social-icon { font-size: 22px; margin-bottom: 6px; }
  .social-name { font-size: 11px; font-weight: 500; color: var(--navy-primary); letter-spacing: 0.04em; }

  .form-section { background: var(--white); border: 0.5px solid rgba(26,39,68,0.1); border-radius: var(--radius-lg); overflow: hidden; }
  .form-section-head { background: var(--navy-primary); padding: 20px 24px; }
  .form-section-title { font-family: var(--font-display); font-size: 20px; font-weight: 500; color: var(--rice-paper); margin-bottom: 4px; }
  .form-section-cn { font-family: var(--font-cn); font-size: 12px; color: var(--brass-gold); letter-spacing: 0.1em; }
  .form-section-body { padding: 32px 24px; text-align: center; }
  .form-placeholder { background: #f8f6f0; border: 1.5px dashed rgba(201,168,76,0.4); border-radius: var(--radius-lg); padding: 40px 24px; margin-bottom: 20px; }
  .form-placeholder-icon { font-family: var(--font-cn); font-size: 32px; color: var(--brass-gold); opacity: 0.5; margin-bottom: 12px; }
  .form-placeholder-title { font-size: 14px; font-weight: 500; color: var(--navy-primary); margin-bottom: 6px; }
  .form-placeholder-note { font-size: 12px; color: #888; line-height: 1.6; max-width: 400px; margin: 0 auto 20px; }
  .form-cta-btn {
    display: inline-flex; align-items: center; gap: 8px; padding: 12px 28px; background: var(--brass-gold); color: var(--navy-deep);
    border-radius: var(--radius-sm); font-size: 12px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; transition: background 0.2s;
  }
  .form-cta-btn:hover { background: #b8943e; color: var(--navy-deep); }
  .form-cta-btn svg { width: 14px; height: 14px; flex-shrink: 0; }
  .form-alt-note { font-size: 12px; color: #888; margin-top: 16px; }
  .form-alt-note a { color: var(--brass-gold); text-decoration: underline; }

  .response-note { background: rgba(201,168,76,0.06); border: 0.5px solid rgba(201,168,76,0.2); border-radius: var(--radius-md); padding: 16px 20px; font-size: 12px; color: #555; line-height: 1.65; margin-top: 20px; }
  .response-note strong { color: var(--navy-primary); font-weight: 500; }

  @media (max-width: 900px) {
    .contact-layout { grid-template-columns: 1fr; gap: 32px; }
    .social-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 480px) {
    .social-grid { grid-template-columns: 1fr; }
  }
---

    <!-- ── Page Hero ──────────────────────────────────────── -->
    <section class="page-hero">

---
layout: layout.njk
permalink: "/gallery.html"
title: "Gallery — Quan Zhen Cultural Society · 全真教化協會"
description: "Photo gallery of Quan Zhen Cultural Society (全真教化協會) — events, rituals, classes, and community gatherings in Singapore."
ogTitle: "Gallery — Quan Zhen Cultural Society"
ogDescription: "Photos from Quan Zhen Cultural Society events, rituals, and community gatherings in Singapore."
activeNav: gallery
bilingualNav: false
showOfferings: false
pageStyle: |
  .page-hero { background: var(--navy-primary); padding: 140px 0 80px; border-bottom: 1px solid rgba(201,168,76,0.2); }
  .page-hero-inner { max-width: 640px; }
  .page-hero h1 { color: var(--rice-paper); margin-bottom: 16px; }
  .page-hero p { color: var(--muted-sky); font-size: 16px; line-height: 1.75; }

  .filter-bar { background: var(--navy-deep); border-bottom: 1px solid rgba(201,168,76,0.15); position: sticky; top: 64px; z-index: 100; }
  .filter-bar-inner { display: flex; gap: 0; flex-wrap: wrap; }
  .filter-tab {
    padding: 16px 24px; font-size: 11px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted-sky);
    cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.2s; white-space: nowrap; background: none;
    border-left: none; border-right: none; border-top: none; font-family: var(--font-body);
  }
  .filter-tab:hover, .filter-tab.active { color: var(--brass-gold); border-bottom-color: var(--brass-gold); }

  .album-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .album-card { background: var(--white); border-radius: var(--radius-lg); overflow: hidden; border: 0.5px solid rgba(26,39,68,0.1); cursor: pointer; transition: transform 0.2s, border-color 0.2s; }
  .album-card:hover { transform: translateY(-3px); border-color: rgba(201,168,76,0.4); }
  .album-cover { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; background: var(--navy-primary); }
  .album-cover-placeholder {
    width: 100%; aspect-ratio: 4/3; background: linear-gradient(135deg, #1A2744 0%, #111D38 100%);
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px;
  }
  .album-cover-placeholder-cn { font-family: var(--font-cn); font-size: 36px; color: rgba(201,168,76,0.3); line-height: 1; }
  .album-cover-placeholder-note { font-size: 10px; color: rgba(143,163,200,0.4); letter-spacing: 0.08em; text-transform: uppercase; }
  .album-info { padding: 16px; }
  .album-tag { font-size: 10px; font-weight: 500; letter-spacing: 0.08em; padding: 2px 8px; border-radius: 20px; display: inline-block; margin-bottom: 8px; }
  .tag-ritual { background: rgba(139,42,42,0.08); color: var(--cinnabar); }
  .tag-class { background: rgba(26,39,68,0.08); color: var(--navy-primary); }
  .tag-community { background: rgba(201,168,76,0.12); color: #7A5F1A; }
  .tag-annual { background: rgba(15,110,86,0.1); color: #0F6E56; }
  .album-title { font-family: var(--font-display); font-size: 17px; font-weight: 500; color: var(--navy-primary); margin-bottom: 4px; line-height: 1.3; }
  .album-date { font-size: 11px; color: #888; margin-bottom: 6px; }
  .album-count { font-size: 11px; color: var(--muted-sky); }

  .lightbox {
    display: none; position: fixed; inset: 0; background: rgba(17,29,56,0.97); z-index: 2000;
    flex-direction: column; align-items: center; justify-content: center; padding: 20px;
  }
  .lightbox.open { display: flex; }
  .lightbox-header {
    position: absolute; top: 0; left: 0; right: 0; padding: 16px 24px; display: flex; justify-content: space-between;
    align-items: center; background: rgba(17,29,56,0.8); border-bottom: 0.5px solid rgba(201,168,76,0.15);
  }
  .lightbox-title { font-family: var(--font-display); font-size: 16px; color: var(--rice-paper); }
  .lightbox-close {
    width: 36px; height: 36px; border-radius: 50%; background: rgba(245,237,216,0.1); border: 0.5px solid rgba(245,237,216,0.2);
    color: var(--rice-paper); font-size: 18px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: background 0.2s;
  }
  .lightbox-close:hover { background: rgba(245,237,216,0.2); }
  .lightbox-photos {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 8px; width: 100%; max-width: 1000px;
    max-height: calc(100vh - 120px); overflow-y: auto; margin-top: 60px; padding: 20px 0;
  }
  .lightbox-photo { aspect-ratio: 1; object-fit: cover; border-radius: var(--radius-md); cursor: zoom-in; transition: transform 0.2s; }
  .lightbox-photo:hover { transform: scale(1.02); }
  .lightbox-placeholder {
    aspect-ratio: 1; background: rgba(245,237,216,0.04); border: 1px dashed rgba(201,168,76,0.2); border-radius: var(--radius-md);
    display: flex; align-items: center; justify-content: center; font-size: 11px; color: rgba(143,163,200,0.4); letter-spacing: 0.06em; text-align: center; padding: 12px;
  }

  @media (max-width: 900px) {
    .album-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .album-grid { grid-template-columns: 1fr; }
    .lightbox-photos { grid-template-columns: repeat(2, 1fr); }
  }
---

    <!-- ── Page Hero ──────────────────────────────────────── -->
    <section class="page-hero">
      <div class="container">
        <div class="page-hero-inner">
          <p class="eyebrow" style="margin-bottom:12px;">In pictures · 圖集</p>
          <span class="cn-text" style="display:block; font-size:13px; margin-bottom:16px;">活動相簿</span>
          <h1>Gallery</h1>
          <p>A visual record of our community — rituals, classes, festivals, and the people who make Quan Zhen Cultural Society what it is. Browse by album below.</p>
        </div>
      </div>
    </section>

    <!-- ── Filter bar ─────────────────────────────────────── -->
    <div class="filter-bar">
      <div class="container">
        <div class="filter-bar-inner">
          <button class="filter-tab active" data-filter="all">All albums</button>
          <button class="filter-tab" data-filter="ritual">Rituals</button>
          <button class="filter-tab" data-filter="class">Classes</button>
          <button class="filter-tab" data-filter="community">Community</button>
          <button class="filter-tab" data-filter="annual">Annual Events</button>
        </div>
      </div>
    </div>

    <!-- ── Albums (dynamic — sourced from content/gallery/*.md) ── -->
    <section class="section section-paper">
      <div class="container">

        {% set galleryCategoryIcons = { "ritual": "禮", "class": "學", "annual": "慶", "community": "聚" } %}
        {% set galleryCategoryLabels = { "ritual": "Ritual", "class": "Class", "annual": "Annual Event", "community": "Community" } %}

        <div class="album-grid" id="album-grid">
        {% if collections.galleryAlbums and collections.galleryAlbums.length %}
          {% for album in collections.galleryAlbums %}
          <div class="album-card"
               data-category="{{ album.data.category }}"
               data-title="{% if album.data.title_cn %}{{ album.data.title_cn }} · {% endif %}{{ album.data.title }}"
               data-photos="{{ album.data.photos | join(',') if album.data.photos and album.data.photos.length else '' }}"
               onclick="openAlbum(this)">
            {% if album.data.cover %}
            <img src="{{ album.data.cover }}" alt="{{ album.data.title }}" class="album-cover">
            {% else %}
            <div class="album-cover-placeholder">
              <div class="album-cover-placeholder-cn">{{ galleryCategoryIcons[album.data.category] or "相" }}</div>
              <div class="album-cover-placeholder-note">Add cover photo</div>
            </div>
            {% endif %}
            <div class="album-info">
              <span class="album-tag tag-{{ album.data.category }}">{{ galleryCategoryLabels[album.data.category] or album.data.category }}</span>
              <div class="album-title">{% if album.data.title_cn %}{{ album.data.title_cn }} · {% endif %}{{ album.data.title }}</div>
              <div class="album-date">{{ album.data.date | readableDate }}</div>
              <div class="album-count">
                {% if album.data.photos and album.data.photos.length %}{{ album.data.photos.length }} photo{% if album.data.photos.length != 1 %}s{% endif %}{% else %}Photos coming soon{% endif %}
              </div>
            </div>
          </div>
          {% endfor %}
        {% else %}
          <!-- No published albums yet — showing planned albums as a preview -->

          <div class="album-card" data-category="annual" data-title="10th Anniversary Celebration" data-photos="" onclick="openAlbum(this)">
            <div class="album-cover-placeholder">
              <div class="album-cover-placeholder-cn">慶</div>
              <div class="album-cover-placeholder-note">Add cover photo</div>
            </div>
            <div class="album-info">
              <span class="album-tag tag-annual">Annual Event</span>
              <div class="album-title">10th Anniversary Celebration</div>
              <div class="album-date">2026</div>
              <div class="album-count">Photos coming soon</div>
            </div>
          </div>

          <div class="album-card" data-category="ritual" data-title="北斗禮斗科儀 · Monthly Lidou Ritual" data-photos="" onclick="openAlbum(this)">
            <div class="album-cover-placeholder">
              <div class="album-cover-placeholder-cn">禮</div>
              <div class="album-cover-placeholder-note">Add cover photo</div>
            </div>
            <div class="album-info">
              <span class="album-tag tag-ritual">Ritual</span>
              <div class="album-title">北斗禮斗科儀 · Monthly Lidou Ritual</div>
              <div class="album-date">Recurring · Last Sunday of month</div>
              <div class="album-count">Photos coming soon</div>
            </div>
          </div>

          <div class="album-card" data-category="annual" data-title="中元節科儀 · Zhong Yuan Jie" data-photos="" onclick="openAlbum(this)">
            <div class="album-cover-placeholder">
              <div class="album-cover-placeholder-cn">中</div>
              <div class="album-cover-placeholder-note">Add cover photo</div>
            </div>
            <div class="album-info">
              <span class="album-tag tag-annual">Annual Event</span>
              <div class="album-title">中元節科儀 · Zhong Yuan Jie</div>
              <div class="album-date">Lunar 7th Month</div>
              <div class="album-count">Photos coming soon</div>
            </div>
          </div>

          <div class="album-card" data-category="annual" data-title="謝太歲科儀 · Thank Taisui Ritual" data-photos="" onclick="openAlbum(this)">
            <div class="album-cover-placeholder">
              <div class="album-cover-placeholder-cn">謝</div>
              <div class="album-cover-placeholder-note">Add cover photo</div>
            </div>
            <div class="album-info">
              <span class="album-tag tag-annual">Annual Event</span>
              <div class="album-title">謝太歲科儀 · Thank Taisui Ritual</div>
              <div class="album-date">Before Winter Solstice</div>
              <div class="album-count">Photos coming soon</div>
            </div>
          </div>

          <div class="album-card" data-category="class" data-title="Sunday Scripture Classes · 週日誦經班" data-photos="" onclick="openAlbum(this)">
            <div class="album-cover-placeholder">
              <div class="album-cover-placeholder-cn">誦</div>
              <div class="album-cover-placeholder-note">Add cover photo</div>
            </div>
            <div class="album-info">
              <span class="album-tag tag-class">Class</span>
              <div class="album-title">Sunday Scripture Classes · 週日誦經班</div>
              <div class="album-date">Every Sunday</div>
              <div class="album-count">Photos coming soon</div>
            </div>
          </div>

          <div class="album-card" data-category="community" data-title="Community Gatherings · 社群活動" data-photos="" onclick="openAlbum(this)">
            <div class="album-cover-placeholder">
              <div class="album-cover-placeholder-cn">聚</div>
              <div class="album-cover-placeholder-note">Add cover photo</div>
            </div>
            <div class="album-info">
              <span class="album-tag tag-community">Community</span>
              <div class="album-title">Community Gatherings · 社群活動</div>
              <div class="album-date">Various</div>
              <div class="album-count">Photos coming soon</div>
            </div>
          </div>

        {% endif %}
        </div>

      </div>
    </section>

    <!-- ── Lightbox ───────────────────────────────────────────── -->
    <div class="lightbox" id="lightbox">
      <div class="lightbox-header">
        <div class="lightbox-title" id="lightbox-title"></div>
        <button class="lightbox-close" onclick="closeLightbox()" aria-label="Close">✕</button>
      </div>
      <div class="lightbox-photos" id="lightbox-photos"></div>
    </div>

    <script>
      // Filter tabs
      const galleryFilterTabs = document.querySelectorAll('.filter-tab');
      const galleryAlbumCards = document.querySelectorAll('.album-card');
      galleryFilterTabs.forEach(tab => {
        tab.addEventListener('click', () => {
          galleryFilterTabs.forEach(t => t.classList.remove('active'));
          tab.classList.add('active');
          const filter = tab.dataset.filter;
          galleryAlbumCards.forEach(card => {
            card.style.display = (filter === 'all' || card.dataset.category === filter) ? '' : 'none';
          });
        });
      });

      // Lightbox
      function openAlbum(card) {
        const title = card.dataset.title;
        const photos = (card.dataset.photos || '').split(',').filter(p => p && p.trim());
        const container = document.getElementById('lightbox-photos');
        document.getElementById('lightbox-title').textContent = title;
        container.innerHTML = '';

        if (photos.length === 0) {
          container.innerHTML = '<div style="color:rgba(143,163,200,0.6); font-size:14px; text-align:center; padding:40px; grid-column:1/-1;">Photos for this album are coming soon.</div>';
        } else {
          photos.forEach(url => {
            const img = document.createElement('img');
            img.src = url.trim();
            img.className = 'lightbox-photo';
            img.loading = 'lazy';
            container.appendChild(img);
          });
        }
        document.getElementById('lightbox').classList.add('open');
        document.body.style.overflow = 'hidden';
      }

      function closeLightbox() {
        document.getElementById('lightbox').classList.remove('open');
        document.body.style.overflow = '';
      }

      document.addEventListener('keydown', e => {
        if (e.key === 'Escape') closeLightbox();
      });

      document.getElementById('lightbox').addEventListener('click', function(e) {
        if (e.target === this) closeLightbox();
      });
    </script>
